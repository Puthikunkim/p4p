{
  "schema_version": "1.0.0",
  "stream": {
    "name": "om.cognitive",
    "source_id": "fixture-01",
    "nominal_srate": 10
  },
  "channels": [
    {
      "name": "cognitive_load",
      "unit": "normalized",
      "type": "scalar",
      "range": { "min": 0, "max": 1 },
      "display": { "hint": "stat_card", "label": "Cognitive Load", "precision": 2, "group": "physiological" }
    },
    {
      "name": "hrv",
      "unit": "BPM",
      "type": "timeseries",
      "range": { "min": 40, "max": 120 },
      "display": { "hint": "line_chart", "label": "HRV", "window_s": 30, "group": "physiological" }
    },
    {
      "name": "affect",
      "unit": "category",
      "type": "categorical",
      "categories": ["calm", "stressed", "bored", "engaged"],
      "display": { "hint": "quadrant", "label": "Affective State", "group": "physiological" }
    },
    {
      "name": "response_latency",
      "unit": "s",
      "type": "scalar",
      "range": { "min": 0, "max": 15 },
      "display": { "hint": "stat_card", "label": "Response Latency", "precision": 1, "group": "behavioural" }
    },
    {
      "name": "response_accuracy",
      "unit": "%",
      "type": "scalar",
      "range": { "min": 0, "max": 100 },
      "display": { "hint": "stat_card", "label": "Response Accuracy", "precision": 0, "group": "behavioural" }
    },
    {
      "name": "clarification_reqs",
      "unit": "/task",
      "type": "scalar",
      "range": { "min": 0, "max": 10 },
      "display": { "hint": "stat_card", "label": "Clarification Reqs", "precision": 1, "group": "behavioural" }
    },
    {
      "name": "idle_time",
      "unit": "s",
      "type": "scalar",
      "range": { "min": 0, "max": 30 },
      "display": { "hint": "stat_card", "label": "Idle Time", "precision": 1, "group": "behavioural" }
    },
    {
      "name": "gaze_dwell_time",
      "unit": "s",
      "type": "scalar",
      "range": { "min": 0, "max": 30 },
      "display": { "hint": "stat_card", "label": "Gaze Dwell Time", "precision": 1, "group": "behavioural" }
    },
    {
      "name": "gaze_switching_rate",
      "unit": "/s",
      "type": "scalar",
      "range": { "min": 0, "max": 2 },
      "display": { "hint": "stat_card", "label": "Gaze Switching Rate", "precision": 2, "group": "behavioural" }
    }
  ]
}
