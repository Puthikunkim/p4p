{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcore/contracts/rule_grammar",
  "title": "Rule Grammar — Contract 2",
  "description": "Declarative IF→THEN rule files authored in the UI or dropped into backend/rules/. The engine hot-reloads these files via watchdog.",
  "type": "object",
  "required": ["id", "schema_version", "when", "then"],
  "additionalProperties": false,
  "properties": {
    "id":             { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description":    { "type": "string" },
    "enabled":        { "type": "boolean", "default": true },
    "when":           { "$ref": "#/$defs/condition_group" },
    "then":           { "$ref": "#/$defs/then_clause" }
  },
  "$defs": {
    "condition_group": {
      "type": "object",
      "oneOf": [
        {
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/condition_item" } }
          }
        },
        {
          "required": ["any"],
          "additionalProperties": false,
          "properties": {
            "any": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/condition_item" } }
          }
        }
      ]
    },
    "condition_item": {
      "type": "object",
      "required": ["signal", "op"],
      "additionalProperties": false,
      "properties": {
        "signal":    { "type": "string", "minLength": 1 },
        "op":        { "enum": [">", ">=", "<", "<=", "==", "!=", "between"] },
        "threshold": { "type": "number" },
        "low":       { "type": "number" },
        "high":      { "type": "number" },
        "value":     { "type": "string" },
        "sustain_s": { "type": "number", "minimum": 0 }
      }
    },
    "then_clause": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["set"] },
        { "required": ["action"] }
      ],
      "properties": {
        "set": { "$ref": "#/$defs/set_action" },
        "action": { "$ref": "#/$defs/invoke_action" },
        "cooldown_s": { "type": "number", "minimum": 0 }
      },
      "$comment": "A rule fires exactly one output: 'set' (change an object status) or 'action' (invoke a parameterless Unity command)."
    },
    "set_action": {
      "type": "object",
      "required": ["target", "status", "value"],
      "additionalProperties": false,
      "properties": {
        "target": { "$ref": "#/$defs/target" },
        "status": { "type": "string", "minLength": 1 },
        "value":  {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ]
        }
      }
    },
    "target": {
      "type": "object",
      "oneOf": [
        {
          "required": ["tag"],
          "additionalProperties": false,
          "properties": { "tag": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["id"],
          "additionalProperties": false,
          "properties": { "id": { "type": "string", "minLength": 1 } }
        }
      ]
    },
    "invoke_action": {
      "type": "object",
      "required": ["action"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/$defs/target" }
      },
      "$comment": "Parameterless command. Omit 'target' for a scene-level action; include a tag/id target for an object-level one."
    }
  }
}
